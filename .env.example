VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Optional: when using Naver through Firebase OIDC custom provider
# Example: oidc.naver
VITE_FIREBASE_NAVER_PROVIDER_ID=oidc.naver

# Optional: backend copilot role SDK
COPILOT_API_KEY=
COPILOT_MODEL=gpt-4o-mini
COPILOT_API_URL=https://api.openai.com/v1/chat/completions

# Backend security/deploy options
NODE_ENV=development
AUTH_PORT=4000
AUTH_JWT_SECRET=replace-with-strong-access-secret
AUTH_REFRESH_SECRET=replace-with-strong-refresh-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
